# 只填写实际启用的 Provider；禁止把本文件中的真实密钥提交到 Git。
# 默认安装仅包含 OpenAI；其他原生集成按 README 的可选依赖命令安装。
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Claude / Anthropic 原生 LangChain Provider。
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# Gemini / Google AI Studio 原生 LangChain Provider。
GOOGLE_API_KEY=

# DeepSeek 原生 LangChain Provider；deepseek-chat 支持本项目所需的结构化输出。
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=

# Qwen / DashScope 原生 LangChain Provider。
DASHSCOPE_API_KEY=
# DASHSCOPE_API_BASE=

# GLM 使用 LangChain ChatOpenAI 连接 ZhipuAI 的 OpenAI 兼容端点。
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=

# 任意符合 OpenAI Chat Completions 协议的第三方中转站。
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
# 可选 JSON：用于 default_headers、extra_body 等中转站专有参数。
# OPENAI_COMPATIBLE_OPTIONS={"default_headers":{"X-Tenant":"tenant-a"}}

# OpenRouter 和 LiteLLM 建议使用各自专用 LangChain Provider。
OPENROUTER_API_KEY=
# LiteLLM 根据 model 名称读取其下游 Provider 的标准环境变量。

# 可选：覆盖 Alembic 和长期 Memory 应用数据库路径；不得与 checkpoint 共用文件。
# FILE_GOVERNANCE_DATABASE_PATH=.artifacts/database/file-governance-app.sqlite3
