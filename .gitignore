# Python 字节码与解释器缓存
__pycache__/
*.py[cod]
*$py.class

# Python 虚拟环境与依赖管理环境
.venv/
venv/
env/
.tox/
.nox/

# Python 构建、安装与打包产物
build/
dist/
*.egg-info/
.eggs/

# 测试、覆盖率、类型检查与静态检查缓存
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.hypothesis/
test-results/
junit*.xml
coverage.xml
.coverage
.coverage.*
htmlcov/
pytestdebug.log
.benchmarks/
benchmark-results/
*.prof

# IDE、编辑器与操作系统文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# 本地配置、密钥与日志
.env
.env.*
!.env.example
*.log

# 本地或私有 Prompt 可能包含临时规则，不提交到仓库
resources/prompts/*.local.md
resources/prompts/*.private.md

# 0.3.x 受控 Prompt 必须随源码、wheel 和容器共同交付。
!resources/prompts/file_governance_system_v1.md

# Prompt 调试快照和本地生命周期 Hook 审计可能包含运行信息，不提交到仓库
prompt_snapshot*.txt
prompt_snapshot*.json
hook_audit*.json

# 0.5.1 Task、LLM、数据库审计、业务阶段分派和 Team Protocol 快照可能包含运行 ID 与产物引用
task_dag*.json
task_snapshot*.json
task_update*.json
task_progress*.json
todo_snapshot*.json
orchestration_snapshot*.json
cli_output*.json
cli_progress*.json
llm_call*.json
llm_audit*.json
llm_response*.json
subagent_input*.json
subagent_output*.json
subagent_prompt*.json
team_message*.json
team_protocol*.json
dispatch_request*.json
dispatch_result*.json
coordinator_fallback*.json
stage_dispatch*.json
version_summary*.json
checkpoint_snapshot*.json
checkpoint_dump*.json
release_acceptance*.json
provider_smoke*.json
application_database*.json
repository_snapshot*.json
migration_snapshot*.json

# Codex 或其他本地代理生成的工作目录
.agents/
.codex/

# 文件治理运行产物、报告、应用数据库与 LangGraph 状态
.artifacts/
artifacts/
reports/
checkpoints/
database/
.langgraph/

# SQLite 应用数据库、checkpoint 及其事务附属文件
*.sqlite
*.sqlite3
*.sqlite-*
*.sqlite3-*
*.db
*.db-*

# 真实业务输入文件不提交；允许使用 .gitkeep 保留空目录
data/input/*
!data/input/.gitkeep
data/artifacts/

# 人工审核响应包含具体运行 ID，不提交到仓库
review_response.json
review_response*.json

# 本地 Docker 手工测试请求包含运行路径，不提交到仓库
docker_request.json
docker_request*.json

# 客户发送记录可能包含收件人和发送时间，仅允许提交脱敏示例
delivery_log.json
delivery_log*.json
!examples/sample_delivery_log.json

# 本地 Docker Compose 覆盖配置
docker-compose.override.yml

# 文档工具生成的静态站点和缓存；docs 源文件继续纳入版本控制
site/
docs/_build/
.mkdocs_cache/

# Office 打开文件时生成的临时锁文件
~$*.docx
~$*.xlsx
~$*.pptx
